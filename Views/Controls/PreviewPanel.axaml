<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="using:ImvixPro.Views.Controls"
             xmlns:cp="clr-namespace:Avalonia.Controls;assembly=Avalonia.Controls.ColorPicker"
             x:Class="ImvixPro.Views.Controls.PreviewPanel"
             x:CompileBindings="False"
             mc:Ignorable="d">
    <ScrollViewer Margin="8" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto" AllowAutoHide="False">
        <StackPanel Spacing="10" Margin="0,0,12,0">
            <Border Background="{DynamicResource SurfaceSubtleBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="8"
                    Height="240"
                    PointerPressed="OnPreviewPointerPressed">
                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
                    <Button Grid.Column="0"
                            Classes="icon-only pdf-nav"
                            Width="44"
                            Height="44"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Center"
                            IsVisible="{Binding PreviewSelectionState.IsPdfNavigationVisible}"
                            IsEnabled="{Binding PreviewSelectionState.CanGoToPreviousPdfPage}"
                            Command="{Binding GoToPreviousPdfPageCommand}"
                            ToolTip.Tip="{Binding PdfPreviousPageText}">
                        <Path Width="14"
                              Height="14"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              Stretch="Uniform"
                              Stroke="{DynamicResource TextPrimaryBrush}"
                              StrokeThickness="2"
                              StrokeLineCap="Round"
                              Data="M 10 2 L 4 7 L 10 12" />
                    </Button>

                    <Grid Grid.Column="1">
                        <Image Source="{Binding PreviewSelectionState.SelectedPreview}" Stretch="Uniform" />

                        <Border IsVisible="{Binding PreviewSelectionState.IsSelectedPdfLocked}"
                                Background="{DynamicResource PdfLockOverlayBrush}"
                                CornerRadius="8"
                                Padding="18">
                            <Border Classes="pdf-lock-panel"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    MaxWidth="304">
                                <StackPanel HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Spacing="12">
                                    <Border Classes="icon-badge pdf-lock-badge"
                                            HorizontalAlignment="Center">
                                        <Viewbox Width="20"
                                                 Height="20"
                                                 Margin="0"
                                                 Stretch="Uniform"
                                                 HorizontalAlignment="Center"
                                                 VerticalAlignment="Center">
                                            <Path Classes="pdf-lock-solid-icon preview"
                                                  Data="{StaticResource IconLockClosedGeometry}" />
                                        </Viewbox>
                                    </Border>
                                    <TextBlock Text="{Binding PreviewSelectionState.PdfLockedPreviewTitleText}"
                                               FontWeight="SemiBold"
                                               FontSize="16"
                                               TextAlignment="Center" />
                                    <TextBlock Text="{Binding PreviewSelectionState.PdfLockedPreviewDescriptionText}"
                                               Classes="secondary"
                                               MaxWidth="248"
                                               TextAlignment="Center"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                        </Border>
                    </Grid>

                    <Button Grid.Column="2"
                            Classes="icon-only pdf-nav"
                            Width="44"
                            Height="44"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Center"
                            IsVisible="{Binding PreviewSelectionState.IsPdfNavigationVisible}"
                            IsEnabled="{Binding PreviewSelectionState.CanGoToNextPdfPage}"
                            Command="{Binding GoToNextPdfPageCommand}"
                            ToolTip.Tip="{Binding PdfNextPageText}">
                        <Path Width="14"
                              Height="14"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              Stretch="Uniform"
                              Stroke="{DynamicResource TextPrimaryBrush}"
                              StrokeThickness="2"
                              StrokeLineCap="Round"
                              Data="M 4 2 L 10 7 L 4 12" />
                    </Button>
                </Grid>
            </Border>

            <TextBlock Text="{Binding NoPreviewText}" Classes="secondary" />
            <TextBlock Text="{Binding PreviewSelectionState.PreviewSelectionFileText, StringFormat='{}{0}'}" TextTrimming="CharacterEllipsis" />
            <Border IsVisible="{Binding PreviewSelectionState.IsPreviewWindowHintVisible}"
                    Background="{DynamicResource SurfaceAltBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="10">
                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                    <Border Classes="icon-badge"
                            Grid.Column="0"
                            Width="28"
                            Height="28"
                            Padding="0"
                            VerticalAlignment="Top">
                        <Path Classes="line-icon"
                              Width="14"
                              Height="14"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              Data="{StaticResource IconInfoGeometry}" />
                    </Border>
                    <TextBlock Grid.Column="1"
                               Text="{Binding PreviewWindowHintText}"
                               Classes="secondary"
                               TextWrapping="Wrap"
                               VerticalAlignment="Top" />
                </Grid>
            </Border>
            <TextBlock IsVisible="{Binding PreviewSelectionState.IsPdfSelected}"
                       Text="{Binding PreviewSelectionState.PdfPageIndicatorText}"
                       Classes="secondary"
                       FontWeight="SemiBold" />
            <TextBlock IsVisible="{Binding PreviewSelectionState.IsSelectedPdfLocked}"
                       Text="{Binding PreviewSelectionState.PdfLockedActionHintText}"
                       Classes="secondary"
                       TextWrapping="Wrap" />

            <Border DataContext="{Binding TaskAnalysisState}"
                    IsVisible="{Binding HasActiveWarnings}"
                    Background="{DynamicResource DangerBackgroundBrush}"
                    BorderBrush="{DynamicResource DangerBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="10">
                <StackPanel Spacing="6">
                    <TextBlock Text="{Binding WarningsTitleText}" FontWeight="SemiBold" Foreground="{DynamicResource DangerTextBrush}" />
                    <ItemsControl ItemsSource="{Binding ActiveWarnings}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" TextWrapping="Wrap" Foreground="{DynamicResource DangerTextBrush}" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <Border IsVisible="{Binding PreviewSelectionState.IsPdfImageExportVisible}"
                    IsEnabled="{Binding PreviewSelectionState.IsSelectedPdfUnlocked}"
                    Background="{DynamicResource SurfaceAltBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="10">
                <StackPanel Spacing="8">
                    <StackPanel Classes="icon-label">
                        <Border Classes="icon-badge">
                            <Path Classes="line-icon" Data="{StaticResource IconImageGeometry}" />
                        </Border>
                        <TextBlock Text="{Binding PdfImageExportTitleText}" FontWeight="SemiBold" VerticalAlignment="Center" />
                    </StackPanel>

                    <TextBlock IsVisible="{Binding PreviewSelectionState.IsSinglePagePdf}"
                               Text="{Binding PdfSinglePageHintText}"
                               Classes="secondary"
                               TextWrapping="Wrap" />

                    <StackPanel IsVisible="{Binding PreviewSelectionState.IsPdfImageModeSelectorVisible}" Orientation="Horizontal" Spacing="14">
                        <RadioButton GroupName="PdfImageMode"
                                     IsChecked="{Binding PreviewSelectionState.IsPdfImageAllPagesMode, Mode=OneWay}"
                                     Checked="OnPdfImageAllPagesChecked"
                                     Content="{Binding PdfExportAllPagesText}" />
                        <RadioButton GroupName="PdfImageMode"
                                     IsChecked="{Binding PreviewSelectionState.IsPdfImageCurrentPageMode, Mode=OneWay}"
                                     Checked="OnPdfImageCurrentPageChecked"
                                     Content="{Binding PdfExportCurrentPageText}" />
                    </StackPanel>

                    <Grid IsVisible="{Binding PreviewSelectionState.IsPdfImagePageSliderVisible}"
                          ColumnDefinitions="Auto,*,Auto"
                          ColumnSpacing="8">
                        <TextBlock Grid.Column="0" Text="{Binding PdfPageText}" VerticalAlignment="Center" />
                        <Slider Grid.Column="1"
                                Minimum="{Binding PreviewSelectionState.PdfPageMinimum}"
                                Maximum="{Binding PreviewSelectionState.PdfPageMaximum}"
                                Value="{Binding PreviewSelectionState.SelectedPdfPageIndex, Mode=OneWay}"
                                TickFrequency="1"
                                IsSnapToTickEnabled="True"
                                ValueChanged="OnPdfPageSliderValueChanged" />
                        <TextBlock Grid.Column="2"
                                   Text="{Binding PreviewSelectionState.PdfPageIndicatorText}"
                                   VerticalAlignment="Center"
                                   FontWeight="SemiBold" />
                    </Grid>
                </StackPanel>
            </Border>

            <Border IsVisible="{Binding PreviewSelectionState.IsPdfDocumentExportVisible}"
                    IsEnabled="{Binding PreviewSelectionState.IsSelectedPdfUnlocked}"
                    Background="{DynamicResource SurfaceAltBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="10">
                <StackPanel Spacing="8">
                    <StackPanel Classes="icon-label">
                        <Border Classes="icon-badge">
                            <Path Classes="line-icon" Data="{StaticResource IconSaveGeometry}" />
                        </Border>
                        <TextBlock Text="{Binding PdfDocumentExportTitleText}" FontWeight="SemiBold" VerticalAlignment="Center" />
                    </StackPanel>

                    <TextBlock IsVisible="{Binding PreviewSelectionState.IsSinglePagePdf}"
                               Text="{Binding PdfSinglePageHintText}"
                               Classes="secondary"
                               TextWrapping="Wrap" />

                    <StackPanel IsVisible="{Binding PreviewSelectionState.IsPdfDocumentModeSelectorVisible}" Orientation="Horizontal" Spacing="14">
                        <RadioButton GroupName="PdfDocumentMode"
                                     IsChecked="{Binding PreviewSelectionState.IsPdfDocumentAllPagesMode, Mode=OneWay}"
                                     Checked="OnPdfDocumentAllPagesChecked"
                                     Content="{Binding PdfExportAllPagesText}" />
                        <RadioButton GroupName="PdfDocumentMode"
                                     IsChecked="{Binding PreviewSelectionState.IsPdfDocumentCurrentPageMode, Mode=OneWay}"
                                     Checked="OnPdfDocumentCurrentPageChecked"
                                     Content="{Binding PdfExportCurrentPageText}" />
                        <RadioButton GroupName="PdfDocumentMode"
                                     IsChecked="{Binding PreviewSelectionState.IsPdfDocumentPageRangeMode, Mode=OneWay}"
                                     Checked="OnPdfDocumentRangeChecked"
                                     Content="{Binding PdfExportPageRangeText}" />
                        <RadioButton GroupName="PdfDocumentMode"
                                     IsChecked="{Binding PreviewSelectionState.IsPdfDocumentSplitSinglePagesMode, Mode=OneWay}"
                                     Checked="OnPdfDocumentSplitSinglePagesChecked"
                                     Content="{Binding PdfSplitSinglePagesText}" />
                    </StackPanel>

                    <Grid IsVisible="{Binding PreviewSelectionState.IsPdfDocumentPageSliderVisible}"
                          ColumnDefinitions="Auto,*,Auto"
                          ColumnSpacing="8">
                        <TextBlock Grid.Column="0" Text="{Binding PdfPageText}" VerticalAlignment="Center" />
                        <Slider Grid.Column="1"
                                Minimum="{Binding PreviewSelectionState.PdfPageMinimum}"
                                Maximum="{Binding PreviewSelectionState.PdfPageMaximum}"
                                Value="{Binding PreviewSelectionState.SelectedPdfPageIndex, Mode=OneWay}"
                                TickFrequency="1"
                                IsSnapToTickEnabled="True"
                                ValueChanged="OnPdfPageSliderValueChanged" />
                        <TextBlock Grid.Column="2"
                                   Text="{Binding PreviewSelectionState.PdfPageIndicatorText}"
                                   VerticalAlignment="Center"
                                   FontWeight="SemiBold" />
                    </Grid>

                    <StackPanel IsVisible="{Binding PreviewSelectionState.IsPdfDocumentRangeSliderVisible}" Spacing="6">
                        <TextBlock Text="{Binding PdfExportPageRangeText}" />
                        <controls:PageRangeSelector Minimum="{Binding PreviewSelectionState.PdfRangeMinimum}"
                                                    Maximum="{Binding PreviewSelectionState.PdfRangeMaximum}"
                                                    StartValue="{Binding PreviewSelectionState.SelectedPdfRangeStartIndex, Mode=OneWay}"
                                                    EndValue="{Binding PreviewSelectionState.SelectedPdfRangeEndIndex, Mode=OneWay}"
                                                    RangeChanged="OnPdfRangeChanged" />
                        <TextBlock Text="{Binding PreviewSelectionState.PdfPageRangeIndicatorText}" Classes="secondary" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border IsVisible="{Binding PreviewSelectionState.IsGifPreviewVisible}"
                    Background="{DynamicResource SurfaceAltBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="10">
                <StackPanel Spacing="8">
                    <StackPanel Classes="icon-label">
                        <Border Classes="icon-badge">
                            <Path Classes="line-icon" Data="{StaticResource IconPlayGeometry}" />
                        </Border>
                        <TextBlock Text="{Binding GifHandlingText}" FontWeight="SemiBold" VerticalAlignment="Center" />
                    </StackPanel>
                    <ComboBox IsVisible="{Binding PreviewSelectionState.IsGifHandlingSelectorVisible}"
                              ItemsSource="{Binding GifHandlingModes}"
                              SelectedItem="{Binding SelectedGifHandlingModeOption}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding DisplayName}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <StackPanel IsVisible="{Binding PreviewSelectionState.IsGifPdfModeSelectorVisible}" Orientation="Horizontal" Spacing="14">
                        <RadioButton GroupName="GifPdfMode"
                                     IsChecked="{Binding PreviewSelectionState.IsGifPdfExportAllFramesMode, Mode=OneWay}"
                                     Checked="OnGifPdfAllFramesChecked"
                                     Content="{Binding GifPdfExportAllFramesText}" />
                        <RadioButton GroupName="GifPdfMode"
                                     IsChecked="{Binding PreviewSelectionState.IsGifPdfExportCurrentFrameMode, Mode=OneWay}"
                                     Checked="OnGifPdfCurrentFrameChecked"
                                     Content="{Binding GifPdfExportCurrentFrameText}" />
                    </StackPanel>
                    <TextBlock IsVisible="{Binding PreviewSelectionState.IsGifPdfModeSelectorVisible}"
                               Text="{Binding GifPdfOutputDirectoryNoteText}"
                               Classes="secondary"
                               TextWrapping="Wrap" />
                    <Grid IsVisible="{Binding PreviewSelectionState.IsGifSpecificFrameControlsVisible}"
                          ColumnDefinitions="Auto,*,Auto"
                          ColumnSpacing="8">
                        <Button Grid.Column="0"
                                Classes="icon-only"
                                Command="{Binding ToggleGifSpecificFramePlaybackCommand}"
                                IsEnabled="{Binding PreviewSelectionState.CanAdjustGifSpecificFrame}"
                                ToolTip.Tip="{Binding GifSpecificFramePlaybackButtonText}">
                            <Grid Width="16" Height="16">
                                <Path IsVisible="{Binding PreviewSelectionState.IsGifSpecificFramePlaybackPaused}"
                                      Classes="line-icon"
                                      Data="{StaticResource IconPlayGeometry}" />
                                <Path IsVisible="{Binding PreviewSelectionState.IsGifSpecificFramePlaying}"
                                      Classes="line-icon"
                                      Data="{StaticResource IconPauseGeometry}" />
                            </Grid>
                        </Button>
                        <Slider Grid.Column="1"
                                Minimum="0"
                                Maximum="{Binding PreviewSelectionState.GifSpecificFrameMaximum}"
                                Value="{Binding PreviewSelectionState.GifSpecificFrameSliderValue, Mode=OneWay}"
                                ValueChanged="OnGifSpecificFrameSliderValueChanged"
                                TickFrequency="1"
                                IsSnapToTickEnabled="True"
                                IsEnabled="{Binding PreviewSelectionState.CanAdjustGifSpecificFrame}" />
                        <TextBlock Grid.Column="2"
                                   MinWidth="28"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Right"
                                   TextAlignment="Right"
                                   VerticalAlignment="Center"
                                   Text="{Binding PreviewSelectionState.GifSpecificFrameCountdownText}" />
                    </Grid>
                </StackPanel>
            </Border>

            <Border IsVisible="{Binding PreviewSelectionState.IsSvgPreviewVisible}"
                    Background="{DynamicResource SurfaceAltBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="10">
                <StackPanel Spacing="8">
                    <StackPanel Classes="icon-label">
                        <Border Classes="icon-badge">
                            <Path Classes="line-icon" Data="{StaticResource IconVectorGeometry}" />
                        </Border>
                        <TextBlock Text="{Binding SvgSettingsText}" FontWeight="SemiBold" VerticalAlignment="Center" />
                    </StackPanel>
                    <CheckBox IsVisible="{Binding PreviewSelectionState.IsSvgBackgroundToggleVisible}"
                              IsEnabled="{Binding PreviewSelectionState.IsSvgBackgroundToggleEnabled}"
                              IsChecked="{Binding SvgBackgroundToggleValue}"
                              Content="{Binding SvgUseBackgroundText}" />
                    <TextBlock IsVisible="{Binding PreviewSelectionState.IsSvgBackgroundRequiredHintVisible}"
                               Text="{Binding SvgBackgroundRequiredHintText}"
                               Classes="secondary"
                               TextWrapping="Wrap" />
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8" IsVisible="{Binding PreviewSelectionState.IsSvgBackgroundColorVisible}">
                        <TextBlock Grid.Column="0" Text="{Binding SvgBackgroundColorText}" VerticalAlignment="Center" />
                        <TextBox Grid.Column="1" Text="{Binding SvgBackgroundColor, UpdateSourceTrigger=LostFocus}" Watermark="#FFFFFFFF" />
                    </Grid>
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8" IsVisible="{Binding PreviewSelectionState.IsSvgBackgroundColorVisible}">
                        <TextBlock Grid.Column="0" Text="{Binding SvgBackgroundColorRgbText}" VerticalAlignment="Center" />
                        <TextBox Grid.Column="1" Text="{Binding SvgBackgroundColorRgb, UpdateSourceTrigger=LostFocus}" Watermark="255,255,255" />
                    </Grid>
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8" IsVisible="{Binding PreviewSelectionState.IsSvgBackgroundColorVisible}">
                        <TextBlock Grid.Column="0" Text="{Binding SvgColorPickerText}" VerticalAlignment="Top" Margin="0,6,0,0" />
                        <cp:ColorView Grid.Column="1"
                                      MinHeight="220"
                                      Color="{Binding SvgBackgroundColorValue}"
                                      IsAlphaEnabled="False"
                                      IsAlphaVisible="False"
                                      IsColorModelVisible="False"
                                      IsComponentSliderVisible="False"
                                      IsComponentTextInputVisible="False" />
                    </Grid>
                    <TextBlock IsVisible="{Binding PreviewSelectionState.IsSvgBackgroundColorVisible}" Text="{Binding SvgBackgroundColorHintText}" Classes="secondary" TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <Border IsVisible="{Binding PreviewSelectionState.IsIconPreviewVisible}"
                    Background="{DynamicResource SurfaceAltBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="10">
                <StackPanel Spacing="8">
                    <StackPanel Classes="icon-label">
                        <Border Classes="icon-badge">
                            <Path Classes="line-icon" Data="{StaticResource IconImageGeometry}" />
                        </Border>
                        <TextBlock Text="{Binding IconSettingsText}" FontWeight="SemiBold" VerticalAlignment="Center" />
                    </StackPanel>
                    <CheckBox IsVisible="{Binding PreviewSelectionState.IsIconTransparencyToggleVisible}"
                              IsChecked="{Binding IconUseTransparency}"
                              Content="{Binding IconUseTransparencyText}" />
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8" IsVisible="{Binding PreviewSelectionState.IsIconBackgroundColorVisible}">
                        <TextBlock Grid.Column="0" Text="{Binding SvgBackgroundColorText}" VerticalAlignment="Center" />
                        <TextBox Grid.Column="1" Text="{Binding IconBackgroundColor, UpdateSourceTrigger=LostFocus}" Watermark="#FFFFFFFF" />
                    </Grid>
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8" IsVisible="{Binding PreviewSelectionState.IsIconBackgroundColorVisible}">
                        <TextBlock Grid.Column="0" Text="{Binding SvgBackgroundColorRgbText}" VerticalAlignment="Center" />
                        <TextBox Grid.Column="1" Text="{Binding IconBackgroundColorRgb, UpdateSourceTrigger=LostFocus}" Watermark="255,255,255" />
                    </Grid>
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8" IsVisible="{Binding PreviewSelectionState.IsIconBackgroundColorVisible}">
                        <TextBlock Grid.Column="0" Text="{Binding SvgColorPickerText}" VerticalAlignment="Top" Margin="0,6,0,0" />
                        <cp:ColorView Grid.Column="1"
                                      MinHeight="220"
                                      Color="{Binding IconBackgroundColorValue}"
                                      IsAlphaEnabled="False"
                                      IsAlphaVisible="False"
                                      IsColorModelVisible="False"
                                      IsComponentSliderVisible="False"
                                      IsComponentTextInputVisible="False" />
                    </Grid>
                    <TextBlock IsVisible="{Binding PreviewSelectionState.IsIconBackgroundColorVisible}" Text="{Binding SvgBackgroundColorHintText}" Classes="secondary" TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <Border DataContext="{Binding TaskAnalysisState}"
                    IsVisible="{Binding HasConversionPlanHighlights}"
                    Background="{DynamicResource SurfaceAltBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="10">
                <StackPanel Spacing="6">
                    <TextBlock Text="{Binding TaskAnalysisTitleText}" FontWeight="SemiBold" />
                    <ItemsControl ItemsSource="{Binding ConversionPlanHighlights}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" TextWrapping="Wrap" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <Border IsVisible="{Binding PreviewSelectionState.IsGifTrimRangeVisible}"
                    Background="{DynamicResource SurfaceAltBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="10">
                <StackPanel Spacing="8">
                    <StackPanel Classes="icon-label">
                        <Border Classes="icon-badge">
                            <Path Classes="line-icon" Data="{StaticResource IconResizeGeometry}" />
                        </Border>
                        <TextBlock Text="{Binding GifTrimRangeText}" FontWeight="SemiBold" VerticalAlignment="Center" />
                    </StackPanel>
                    <controls:GifFrameRangeSelector Minimum="{Binding PreviewSelectionState.GifTrimRangeMinimum}"
                                                    Maximum="{Binding PreviewSelectionState.GifTrimRangeMaximum}"
                                                    StartValue="{Binding PreviewSelectionState.SelectedGifTrimStartIndex, Mode=OneWay}"
                                                    EndValue="{Binding PreviewSelectionState.SelectedGifTrimEndIndex, Mode=OneWay}"
                                                    RangeChanged="OnGifTrimRangeChanged" />
                </StackPanel>
            </Border>

            <Border DataContext="{Binding TaskAnalysisState}"
                    IsVisible="{Binding HasFormatRecommendation}"
                    Background="{DynamicResource SurfaceAltBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="10">
                <StackPanel Spacing="4">
                    <TextBlock Text="{Binding FormatRecommendationTitleText}" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding FormatRecommendationText}" />
                    <TextBlock Text="{Binding FormatRecommendationReasonText}" Classes="secondary" TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <Border DataContext="{Binding TaskAnalysisState}"
                    IsVisible="{Binding HasSizeEstimate}"
                    Background="{DynamicResource SurfaceAltBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="10">
                <StackPanel Spacing="4">
                    <TextBlock Text="{Binding EstimatedSizeTitleText}" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding OriginalSizeSummaryText}" />
                    <TextBlock Text="{Binding EstimatedSizeSummaryText}" Classes="secondary" />
                    <TextBlock Text="{Binding EstimateDisclaimerText}"
                               Classes="secondary"
                               TextWrapping="Wrap"
                               IsVisible="{Binding HasEstimateDisclaimer}" />
                </StackPanel>
            </Border>

            <Border IsVisible="{Binding NotificationState.HasFailureLog}"
                    Background="{DynamicResource SurfaceAltBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="10">
                <StackPanel Spacing="4">
                    <TextBlock Text="{Binding FailureLogLabelText}" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding NotificationState.LastFailureLogPath}" Classes="secondary" TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <Border Background="{DynamicResource SurfaceAltBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="10">
                <StackPanel Spacing="8">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                        <TextBlock Grid.Column="0" Text="{Binding HistoryTitleText}" FontWeight="SemiBold" VerticalAlignment="Center" />
                        <Button Grid.Column="1"
                                Command="{Binding HistoryState.ClearRecentConversionsCommand}"
                                ToolTip.Tip="{Binding ClearRecentConversionsText}">
                            <StackPanel Classes="icon-label">
                                <Path Classes="line-icon danger" Data="{StaticResource IconTrashGeometry}" />
                                <TextBlock Text="{Binding ClearRecentConversionsText}" />
                            </StackPanel>
                        </Button>
                    </Grid>
                    <TextBlock IsVisible="{Binding HistoryState.IsEmpty}" Text="{Binding HistoryEmptyText}" Classes="secondary" />
                    <ItemsControl IsVisible="{Binding HistoryState.HasRecentConversions}" ItemsSource="{Binding HistoryState.RecentConversions}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource SurfaceBrush}"
                                        BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Padding="8"
                                        Margin="0,0,0,6">
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="{Binding TimestampText}" Classes="secondary" />
                                        <TextBlock Text="{Binding SummaryText}" FontWeight="SemiBold" TextWrapping="Wrap" />
                                        <TextBlock Text="{Binding DetailText}" Classes="secondary" TextWrapping="Wrap" />
                                        <TextBlock IsVisible="{Binding HasFailureLog}" Text="{Binding FailureLogPath}" Classes="secondary" TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <Border IsVisible="{Binding HasFailures}"
                    Background="{DynamicResource DangerBackgroundBrush}"
                    BorderBrush="{DynamicResource DangerBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="10">
                <StackPanel Spacing="6">
                    <TextBlock Text="{Binding FailedFilesText}" FontWeight="SemiBold" Foreground="{DynamicResource DangerTextBrush}" />
                    <ItemsControl ItemsSource="{Binding FailedConversions}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="0,0,0,6">
                                    <TextBlock Text="{Binding FileName}" FontWeight="SemiBold" Foreground="{DynamicResource DangerTextBrush}" />
                                    <TextBlock Text="{Binding Reason}" TextWrapping="Wrap" Foreground="{DynamicResource DangerTextBrush}" />
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
