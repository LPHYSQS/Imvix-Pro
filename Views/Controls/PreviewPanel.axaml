<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="using:ImvixPro.Views.Controls"
             xmlns:cp="clr-namespace:Avalonia.Controls;assembly=Avalonia.Controls.ColorPicker"
             x:Class="ImvixPro.Views.Controls.PreviewPanel"
             x:CompileBindings="False"
             mc:Ignorable="d">
    <ScrollViewer Margin="8" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto" AllowAutoHide="False">
        <StackPanel Spacing="10" Margin="0,0,12,0">
            <Border Background="{DynamicResource SurfaceSubtleBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="8"
                    Height="240"
                    PointerPressed="OnPreviewPointerPressed">
                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
                    <Button Grid.Column="0"
                            Classes="icon-only pdf-nav"
                            Width="44"
                            Height="44"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Center"
                            IsVisible="{Binding IsPdfNavigationVisible}"
                            IsEnabled="{Binding CanGoToPreviousPdfPage}"
                            Command="{Binding GoToPreviousPdfPageCommand}"
                            ToolTip.Tip="{Binding PdfPreviousPageText}">
                        <Path Width="14"
                              Height="14"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              Stretch="Uniform"
                              Stroke="{DynamicResource TextPrimaryBrush}"
                              StrokeThickness="2"
                              StrokeLineCap="Round"
                              Data="M 10 2 L 4 7 L 10 12" />
                    </Button>

                    <Grid Grid.Column="1">
                        <Image Source="{Binding SelectedPreview}" Stretch="Uniform" />

                        <Border IsVisible="{Binding IsSelectedPdfLocked}"
                                Background="{DynamicResource PdfLockOverlayBrush}"
                                CornerRadius="8"
                                Padding="18">
                            <StackPanel HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Spacing="10"
                                        MaxWidth="280">
                                <Border Classes="icon-badge"
                                        Width="40"
                                        Height="40"
                                        Padding="0"
                                        HorizontalAlignment="Center"
                                        Background="{DynamicResource DangerBackgroundBrush}"
                                        BorderBrush="{DynamicResource DangerBorderBrush}">
                                    <Grid Width="18"
                                          Height="18"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center">
                                        <Path Classes="line-icon danger"
                                              Width="18"
                                              Height="18"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Data="{StaticResource IconLockClosedGeometry}" />
                                    </Grid>
                                </Border>
                                <TextBlock Text="{Binding PdfLockedPreviewTitleText}"
                                           FontWeight="SemiBold"
                                           TextAlignment="Center" />
                                <TextBlock Text="{Binding PdfLockedPreviewDescriptionText}"
                                           Classes="secondary"
                                           TextAlignment="Center"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Button Grid.Column="2"
                            Classes="icon-only pdf-nav"
                            Width="44"
                            Height="44"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Center"
                            IsVisible="{Binding IsPdfNavigationVisible}"
                            IsEnabled="{Binding CanGoToNextPdfPage}"
                            Command="{Binding GoToNextPdfPageCommand}"
                            ToolTip.Tip="{Binding PdfNextPageText}">
                        <Path Width="14"
                              Height="14"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              Stretch="Uniform"
                              Stroke="{DynamicResource TextPrimaryBrush}"
                              StrokeThickness="2"
                              StrokeLineCap="Round"
                              Data="M 4 2 L 10 7 L 4 12" />
                    </Button>
                </Grid>
            </Border>

            <TextBlock Text="{Binding NoPreviewText}" Classes="secondary" />
            <TextBlock Text="{Binding CurrentFile, StringFormat='{}{0}'}" TextTrimming="CharacterEllipsis" />
            <Border IsVisible="{Binding IsPreviewWindowHintVisible}"
                    Background="{DynamicResource SurfaceAltBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="10">
                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                    <Border Classes="icon-badge"
                            Grid.Column="0"
                            Width="28"
                            Height="28"
                            Padding="0"
                            VerticalAlignment="Top">
                        <Path Classes="line-icon"
                              Width="14"
                              Height="14"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              Data="{StaticResource IconInfoGeometry}" />
                    </Border>
                    <TextBlock Grid.Column="1"
                               Text="{Binding PreviewWindowHintText}"
                               Classes="secondary"
                               TextWrapping="Wrap"
                               VerticalAlignment="Top" />
                </Grid>
            </Border>
            <TextBlock IsVisible="{Binding IsPdfSelected}"
                       Text="{Binding PdfPageIndicatorText}"
                       Classes="secondary"
                       FontWeight="SemiBold" />
            <TextBlock IsVisible="{Binding IsSelectedPdfLocked}"
                       Text="{Binding PdfLockedActionHintText}"
                       Classes="secondary"
                       TextWrapping="Wrap" />

            <Border IsVisible="{Binding HasActiveWarnings}"
                    Background="{DynamicResource DangerBackgroundBrush}"
                    BorderBrush="{DynamicResource DangerBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="10">
                <StackPanel Spacing="6">
                    <TextBlock Text="{Binding WarningsTitleText}" FontWeight="SemiBold" Foreground="{DynamicResource DangerTextBrush}" />
                    <ItemsControl ItemsSource="{Binding ActiveWarnings}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" TextWrapping="Wrap" Foreground="{DynamicResource DangerTextBrush}" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <Border IsVisible="{Binding IsPdfImageExportVisible}"
                    IsEnabled="{Binding IsSelectedPdfUnlocked}"
                    Background="{DynamicResource SurfaceAltBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="10">
                <StackPanel Spacing="8">
                    <StackPanel Classes="icon-label">
                        <Border Classes="icon-badge">
                            <Path Classes="line-icon" Data="{StaticResource IconImageGeometry}" />
                        </Border>
                        <TextBlock Text="{Binding PdfImageExportTitleText}" FontWeight="SemiBold" VerticalAlignment="Center" />
                    </StackPanel>

                    <TextBlock IsVisible="{Binding IsSinglePagePdf}"
                               Text="{Binding PdfSinglePageHintText}"
                               Classes="secondary"
                               TextWrapping="Wrap" />

                    <StackPanel IsVisible="{Binding IsPdfImageModeSelectorVisible}" Orientation="Horizontal" Spacing="14">
                        <RadioButton GroupName="PdfImageMode"
                                     IsChecked="{Binding IsPdfImageAllPagesMode}"
                                     Checked="OnPdfImageAllPagesChecked"
                                     Content="{Binding PdfExportAllPagesText}" />
                        <RadioButton GroupName="PdfImageMode"
                                     IsChecked="{Binding IsPdfImageCurrentPageMode}"
                                     Checked="OnPdfImageCurrentPageChecked"
                                     Content="{Binding PdfExportCurrentPageText}" />
                    </StackPanel>

                    <Grid IsVisible="{Binding IsPdfImagePageSliderVisible}"
                          ColumnDefinitions="Auto,*,Auto"
                          ColumnSpacing="8">
                        <TextBlock Grid.Column="0" Text="{Binding PdfPageText}" VerticalAlignment="Center" />
                        <Slider Grid.Column="1"
                                Minimum="{Binding PdfPageMinimum}"
                                Maximum="{Binding PdfPageMaximum}"
                                Value="{Binding SelectedPdfPageIndex, Mode=OneWay}"
                                TickFrequency="1"
                                IsSnapToTickEnabled="True"
                                ValueChanged="OnPdfPageSliderValueChanged" />
                        <TextBlock Grid.Column="2"
                                   Text="{Binding PdfPageIndicatorText}"
                                   VerticalAlignment="Center"
                                   FontWeight="SemiBold" />
                    </Grid>
                </StackPanel>
            </Border>

            <Border IsVisible="{Binding IsPdfDocumentExportVisible}"
                    IsEnabled="{Binding IsSelectedPdfUnlocked}"
                    Background="{DynamicResource SurfaceAltBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="10">
                <StackPanel Spacing="8">
                    <StackPanel Classes="icon-label">
                        <Border Classes="icon-badge">
                            <Path Classes="line-icon" Data="{StaticResource IconSaveGeometry}" />
                        </Border>
                        <TextBlock Text="{Binding PdfDocumentExportTitleText}" FontWeight="SemiBold" VerticalAlignment="Center" />
                    </StackPanel>

                    <TextBlock IsVisible="{Binding IsSinglePagePdf}"
                               Text="{Binding PdfSinglePageHintText}"
                               Classes="secondary"
                               TextWrapping="Wrap" />

                    <StackPanel IsVisible="{Binding IsPdfDocumentModeSelectorVisible}" Orientation="Horizontal" Spacing="14">
                        <RadioButton GroupName="PdfDocumentMode"
                                     IsChecked="{Binding IsPdfDocumentAllPagesMode}"
                                     Checked="OnPdfDocumentAllPagesChecked"
                                     Content="{Binding PdfExportAllPagesText}" />
                        <RadioButton GroupName="PdfDocumentMode"
                                     IsChecked="{Binding IsPdfDocumentCurrentPageMode}"
                                     Checked="OnPdfDocumentCurrentPageChecked"
                                     Content="{Binding PdfExportCurrentPageText}" />
                        <RadioButton GroupName="PdfDocumentMode"
                                     IsChecked="{Binding IsPdfDocumentPageRangeMode}"
                                     Checked="OnPdfDocumentRangeChecked"
                                     Content="{Binding PdfExportPageRangeText}" />
                        <RadioButton GroupName="PdfDocumentMode"
                                     IsChecked="{Binding IsPdfDocumentSplitSinglePagesMode}"
                                     Checked="OnPdfDocumentSplitSinglePagesChecked"
                                     Content="{Binding PdfSplitSinglePagesText}" />
                    </StackPanel>

                    <Grid IsVisible="{Binding IsPdfDocumentPageSliderVisible}"
                          ColumnDefinitions="Auto,*,Auto"
                          ColumnSpacing="8">
                        <TextBlock Grid.Column="0" Text="{Binding PdfPageText}" VerticalAlignment="Center" />
                        <Slider Grid.Column="1"
                                Minimum="{Binding PdfPageMinimum}"
                                Maximum="{Binding PdfPageMaximum}"
                                Value="{Binding SelectedPdfPageIndex, Mode=OneWay}"
                                TickFrequency="1"
                                IsSnapToTickEnabled="True"
                                ValueChanged="OnPdfPageSliderValueChanged" />
                        <TextBlock Grid.Column="2"
                                   Text="{Binding PdfPageIndicatorText}"
                                   VerticalAlignment="Center"
                                   FontWeight="SemiBold" />
                    </Grid>

                    <StackPanel IsVisible="{Binding IsPdfDocumentRangeSliderVisible}" Spacing="6">
                        <TextBlock Text="{Binding PdfExportPageRangeText}" />
                        <controls:PageRangeSelector Minimum="{Binding PdfRangeMinimum}"
                                                    Maximum="{Binding PdfRangeMaximum}"
                                                    StartValue="{Binding SelectedPdfRangeStartIndex, Mode=OneWay}"
                                                    EndValue="{Binding SelectedPdfRangeEndIndex, Mode=OneWay}"
                                                    RangeChanged="OnPdfRangeChanged" />
                        <TextBlock Text="{Binding PdfPageRangeIndicatorText}" Classes="secondary" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border IsVisible="{Binding IsGifPreviewVisible}"
                    Background="{DynamicResource SurfaceAltBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="10">
                <StackPanel Spacing="8">
                    <StackPanel Classes="icon-label">
                        <Border Classes="icon-badge">
                            <Path Classes="line-icon" Data="{StaticResource IconPlayGeometry}" />
                        </Border>
                        <TextBlock Text="{Binding GifHandlingText}" FontWeight="SemiBold" VerticalAlignment="Center" />
                    </StackPanel>
                    <ComboBox IsVisible="{Binding IsGifHandlingSelectorVisible}"
                              ItemsSource="{Binding GifHandlingModes}"
                              SelectedItem="{Binding SelectedGifHandlingModeOption}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding DisplayName}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <StackPanel IsVisible="{Binding IsGifPdfModeSelectorVisible}" Orientation="Horizontal" Spacing="14">
                        <RadioButton GroupName="GifPdfMode"
                                     IsChecked="{Binding IsGifPdfExportAllFramesMode}"
                                     Checked="OnGifPdfAllFramesChecked"
                                     Content="{Binding GifPdfExportAllFramesText}" />
                        <RadioButton GroupName="GifPdfMode"
                                     IsChecked="{Binding IsGifPdfExportCurrentFrameMode}"
                                     Checked="OnGifPdfCurrentFrameChecked"
                                     Content="{Binding GifPdfExportCurrentFrameText}" />
                    </StackPanel>
                    <TextBlock IsVisible="{Binding IsGifPdfModeSelectorVisible}"
                               Text="{Binding GifPdfOutputDirectoryNoteText}"
                               Classes="secondary"
                               TextWrapping="Wrap" />
                    <Grid IsVisible="{Binding IsGifSpecificFrameControlsVisible}"
                          ColumnDefinitions="Auto,*,Auto"
                          ColumnSpacing="8">
                        <Button Grid.Column="0"
                                Classes="icon-only"
                                Command="{Binding ToggleGifSpecificFramePlaybackCommand}"
                                IsEnabled="{Binding CanAdjustGifSpecificFrame}"
                                ToolTip.Tip="{Binding GifSpecificFramePlaybackButtonText}">
                            <Grid Width="16" Height="16">
                                <Path IsVisible="{Binding IsGifSpecificFramePlaybackPaused}"
                                      Classes="line-icon"
                                      Data="{StaticResource IconPlayGeometry}" />
                                <Path IsVisible="{Binding IsGifSpecificFramePlaying}"
                                      Classes="line-icon"
                                      Data="{StaticResource IconPauseGeometry}" />
                            </Grid>
                        </Button>
                        <Slider Grid.Column="1"
                                Minimum="0"
                                Maximum="{Binding GifSpecificFrameMaximum}"
                                Value="{Binding GifSpecificFrameSliderValue, Mode=OneWay}"
                                ValueChanged="OnGifSpecificFrameSliderValueChanged"
                                TickFrequency="1"
                                IsSnapToTickEnabled="True"
                                IsEnabled="{Binding CanAdjustGifSpecificFrame}" />
                        <TextBlock Grid.Column="2"
                                   MinWidth="28"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Right"
                                   TextAlignment="Right"
                                   VerticalAlignment="Center"
                                   Text="{Binding GifSpecificFrameCountdownText}" />
                    </Grid>
                </StackPanel>
            </Border>

            <Border IsVisible="{Binding IsSvgPreviewVisible}"
                    Background="{DynamicResource SurfaceAltBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="10">
                <StackPanel Spacing="8">
                    <StackPanel Classes="icon-label">
                        <Border Classes="icon-badge">
                            <Path Classes="line-icon" Data="{StaticResource IconVectorGeometry}" />
                        </Border>
                        <TextBlock Text="{Binding SvgSettingsText}" FontWeight="SemiBold" VerticalAlignment="Center" />
                    </StackPanel>
                    <CheckBox IsVisible="{Binding IsSvgBackgroundToggleVisible}"
                              IsEnabled="{Binding IsSvgBackgroundToggleEnabled}"
                              IsChecked="{Binding SvgBackgroundToggleValue}"
                              Content="{Binding SvgUseBackgroundText}" />
                    <TextBlock IsVisible="{Binding IsSvgBackgroundRequiredHintVisible}"
                               Text="{Binding SvgBackgroundRequiredHintText}"
                               Classes="secondary"
                               TextWrapping="Wrap" />
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8" IsVisible="{Binding IsSvgBackgroundColorVisible}">
                        <TextBlock Grid.Column="0" Text="{Binding SvgBackgroundColorText}" VerticalAlignment="Center" />
                        <TextBox Grid.Column="1" Text="{Binding SvgBackgroundColor, UpdateSourceTrigger=LostFocus}" Watermark="#FFFFFFFF" />
                    </Grid>
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8" IsVisible="{Binding IsSvgBackgroundColorVisible}">
                        <TextBlock Grid.Column="0" Text="{Binding SvgBackgroundColorRgbText}" VerticalAlignment="Center" />
                        <TextBox Grid.Column="1" Text="{Binding SvgBackgroundColorRgb, UpdateSourceTrigger=LostFocus}" Watermark="255,255,255" />
                    </Grid>
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8" IsVisible="{Binding IsSvgBackgroundColorVisible}">
                        <TextBlock Grid.Column="0" Text="{Binding SvgColorPickerText}" VerticalAlignment="Top" Margin="0,6,0,0" />
                        <cp:ColorView Grid.Column="1"
                                      MinHeight="220"
                                      Color="{Binding SvgBackgroundColorValue}"
                                      IsAlphaEnabled="False"
                                      IsAlphaVisible="False"
                                      IsColorModelVisible="False"
                                      IsComponentSliderVisible="False"
                                      IsComponentTextInputVisible="False" />
                    </Grid>
                    <TextBlock IsVisible="{Binding IsSvgBackgroundColorVisible}" Text="{Binding SvgBackgroundColorHintText}" Classes="secondary" TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <Border IsVisible="{Binding IsIconPreviewVisible}"
                    Background="{DynamicResource SurfaceAltBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="10">
                <StackPanel Spacing="8">
                    <StackPanel Classes="icon-label">
                        <Border Classes="icon-badge">
                            <Path Classes="line-icon" Data="{StaticResource IconImageGeometry}" />
                        </Border>
                        <TextBlock Text="{Binding IconSettingsText}" FontWeight="SemiBold" VerticalAlignment="Center" />
                    </StackPanel>
                    <CheckBox IsVisible="{Binding IsIconTransparencyToggleVisible}"
                              IsChecked="{Binding IconUseTransparency}"
                              Content="{Binding IconUseTransparencyText}" />
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8" IsVisible="{Binding IsIconBackgroundColorVisible}">
                        <TextBlock Grid.Column="0" Text="{Binding SvgBackgroundColorText}" VerticalAlignment="Center" />
                        <TextBox Grid.Column="1" Text="{Binding IconBackgroundColor, UpdateSourceTrigger=LostFocus}" Watermark="#FFFFFFFF" />
                    </Grid>
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8" IsVisible="{Binding IsIconBackgroundColorVisible}">
                        <TextBlock Grid.Column="0" Text="{Binding SvgBackgroundColorRgbText}" VerticalAlignment="Center" />
                        <TextBox Grid.Column="1" Text="{Binding IconBackgroundColorRgb, UpdateSourceTrigger=LostFocus}" Watermark="255,255,255" />
                    </Grid>
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8" IsVisible="{Binding IsIconBackgroundColorVisible}">
                        <TextBlock Grid.Column="0" Text="{Binding SvgColorPickerText}" VerticalAlignment="Top" Margin="0,6,0,0" />
                        <cp:ColorView Grid.Column="1"
                                      MinHeight="220"
                                      Color="{Binding IconBackgroundColorValue}"
                                      IsAlphaEnabled="False"
                                      IsAlphaVisible="False"
                                      IsColorModelVisible="False"
                                      IsComponentSliderVisible="False"
                                      IsComponentTextInputVisible="False" />
                    </Grid>
                    <TextBlock IsVisible="{Binding IsIconBackgroundColorVisible}" Text="{Binding SvgBackgroundColorHintText}" Classes="secondary" TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <Border IsVisible="{Binding IsGifTrimRangeVisible}"
                    Background="{DynamicResource SurfaceAltBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="10">
                <StackPanel Spacing="8">
                    <StackPanel Classes="icon-label">
                        <Border Classes="icon-badge">
                            <Path Classes="line-icon" Data="{StaticResource IconResizeGeometry}" />
                        </Border>
                        <TextBlock Text="{Binding GifTrimRangeText}" FontWeight="SemiBold" VerticalAlignment="Center" />
                    </StackPanel>
                    <controls:GifFrameRangeSelector Minimum="{Binding GifTrimRangeMinimum}"
                                                    Maximum="{Binding GifTrimRangeMaximum}"
                                                    StartValue="{Binding SelectedGifTrimStartIndex, Mode=OneWay}"
                                                    EndValue="{Binding SelectedGifTrimEndIndex, Mode=OneWay}"
                                                    RangeChanged="OnGifTrimRangeChanged" />
                </StackPanel>
            </Border>

            <Border IsVisible="{Binding HasFormatRecommendation}"
                    Background="{DynamicResource SurfaceAltBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="10">
                <StackPanel Spacing="4">
                    <TextBlock Text="{Binding FormatRecommendationTitleText}" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding FormatRecommendationText}" />
                    <TextBlock Text="{Binding FormatRecommendationReasonText}" Classes="secondary" TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <Border IsVisible="{Binding HasSizeEstimate}"
                    Background="{DynamicResource SurfaceAltBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="10">
                <StackPanel Spacing="4">
                    <TextBlock Text="{Binding EstimatedSizeTitleText}" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding OriginalSizeSummaryText}" />
                    <TextBlock Text="{Binding EstimatedSizeSummaryText}" Classes="secondary" />
                </StackPanel>
            </Border>

            <Border IsVisible="{Binding HasFailureLog}"
                    Background="{DynamicResource SurfaceAltBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="10">
                <StackPanel Spacing="4">
                    <TextBlock Text="{Binding FailureLogLabelText}" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding LastFailureLogPath}" Classes="secondary" TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <Border Background="{DynamicResource SurfaceAltBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="10">
                <StackPanel Spacing="8">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                        <TextBlock Grid.Column="0" Text="{Binding HistoryTitleText}" FontWeight="SemiBold" VerticalAlignment="Center" />
                        <Button Grid.Column="1"
                                Command="{Binding ClearRecentConversionsCommand}"
                                ToolTip.Tip="{Binding ClearRecentConversionsText}">
                            <StackPanel Classes="icon-label">
                                <Path Classes="line-icon danger" Data="{StaticResource IconTrashGeometry}" />
                                <TextBlock Text="{Binding ClearRecentConversionsText}" />
                            </StackPanel>
                        </Button>
                    </Grid>
                    <TextBlock IsVisible="{Binding IsHistoryEmpty}" Text="{Binding HistoryEmptyText}" Classes="secondary" />
                    <ItemsControl IsVisible="{Binding HasRecentConversions}" ItemsSource="{Binding RecentConversions}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource SurfaceBrush}"
                                        BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Padding="8"
                                        Margin="0,0,0,6">
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="{Binding TimestampText}" Classes="secondary" />
                                        <TextBlock Text="{Binding SummaryText}" FontWeight="SemiBold" TextWrapping="Wrap" />
                                        <TextBlock Text="{Binding DetailText}" Classes="secondary" TextWrapping="Wrap" />
                                        <TextBlock IsVisible="{Binding HasFailureLog}" Text="{Binding FailureLogPath}" Classes="secondary" TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <Border IsVisible="{Binding HasFailures}"
                    Background="{DynamicResource DangerBackgroundBrush}"
                    BorderBrush="{DynamicResource DangerBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="10">
                <StackPanel Spacing="6">
                    <TextBlock Text="{Binding FailedFilesText}" FontWeight="SemiBold" Foreground="{DynamicResource DangerTextBrush}" />
                    <ItemsControl ItemsSource="{Binding FailedConversions}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="0,0,0,6">
                                    <TextBlock Text="{Binding FileName}" FontWeight="SemiBold" Foreground="{DynamicResource DangerTextBrush}" />
                                    <TextBlock Text="{Binding Reason}" TextWrapping="Wrap" Foreground="{DynamicResource DangerTextBrush}" />
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
